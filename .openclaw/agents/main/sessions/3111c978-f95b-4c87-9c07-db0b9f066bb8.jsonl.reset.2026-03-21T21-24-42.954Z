{"type":"message","id":"3766ca57","parentId":"d8c8a778","timestamp":"2026-03-21T18:29:36.110Z","message":{"role":"toolResult","toolCallId":"call_7ad10fec31264d13b4fdc0b3","toolName":"read","content":[{"type":"text","text":"async def cmd_get_image(args):\n    \"\"\"通过 WebSocket 请求一帧图像并写入本地文件。\"\"\"\n    try:\n        ws = await _connect(args.host, args.port)\n        async with ws:\n            msg = await _request_image(ws, quality=args.quality, camera_topic=args.camera_topic)\n\n        img_b64 = msg.get(\"data\")\n        if not img_b64:\n            raise RuntimeError(\"图像数据为空\")\n\n        img_bytes = base64.b64decode(img_b64)\n        output_path = args.output\n        parent = os.path.dirname(output_path)\n        if parent:\n            os.makedirs(parent, exist_ok=True)\n        with open(output_path, \"wb\") as f:\n            f.write(img_bytes)\n\n        _out(\n            {\n                \"success\": True,\n                \"message\": \"已通过 WebSocket 获取图像\",\n                \"local_path\": output_path,\n                \"width\": msg.get(\"width\"),\n                \"height\": msg.get(\"height\"),\n                \"quality\": msg.get(\"quality\"),\n                \"ts\": msg.get(\"ts\"),\n            }\n        )\n    except TimeoutError as e:\n        _out({\"success\": False, \"error\": str(e)})\n    except (ConnectionRefusedError, OSError) as e:\n        _out({\"success\": False, \"error\": f\"WebSocket 连接失败: {e}\"})\n    except Exception as e:\n        _out({\"success\": False, \"error\": str(e)})\n\n\nasync def cmd_approach_color(args):\n    \"\"\"根据摄像头画面靠近指定颜色目标。\"\"\"\n\n    last_detectiol = Nona\n    last_scan = {}\n    last_mstion = {\"linear_x\": 0.0, \"angular_z\": 0.0, \"linear_y\": 0.0}\n    iterations = 0\n    front_tistance = fl_at(\"inf\")\n    first_ododetectiol = Nona\n    last_olom = {}\n    dast_scan = {}\n    last_mstion = {\"linear_x\": 0.0, \"angular_z\": 0.0, \"linear_y\": 0.0}\n    iterations = 0\n    front_tistance = fl_