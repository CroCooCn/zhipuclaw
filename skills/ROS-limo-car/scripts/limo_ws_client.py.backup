                    args.min_
                if emergency_reason is not None:
                    awaiection = detection
                _maybe_wt _send_cmd_vel(ws, 0.0, 0.0, 0.0)
                    _out(
                        {
                            "success": True,
                            "reached": False,
                            "stop_reason": emergency_reason,
                            "iterations": iterations,
                            "scan": last_scan,
                            "selected_front_distance": None if math.isinf(front_distance) else front_distance,
                            "area,
                    args.min_last_detection": last_detection,
                            "last_motion": last_motion,
                        ection = detection
                _maybe_w}
                    )
                    return

                image_msg = await _request_image(ws, quality=args.quality, camera_topic=args.camera_topic)
                frame_bgr = _decode_bgr_image(image_msg.get("data", ""))
                detection = _detect_color_target(
                    frame_bgr,
                    color_ranges,
                    args.min_area,
                    args.min_visible_area,
                )
                last_detection = detection
                _maybe_write_debug_frame(frame_bgr, detection, args.debug_output)

                if detection.get("found"):
                    detected_frames += 1
                    area = float(detection.get("area", 0.0))
                    area_ratio = float(detection.get("area_ratio", 0.0))
                    error_x = float(detection.get("center_error", 0.0))
                    max_seen_area = max(max_seen_area, area)
                    max_seen_area_ratio = max(max_seen_area_ratio, area_ratio)
                    if not detection.get("meets_min_area", True):
                        weak_detected_frames += 1

                    stop_distance_effective = args.stop_distance + max(0.0, args.stop_distance_buffer)
                    area_stop_max_distance_effective = args.stop_area_max_distance + max(0.0, args.stop_distance_buffer)
                    hard_distance_stop_hit = (
                        args.hard_stop_distance > 0.0
                        and (not math.isinf(front_distance))
                        and front_distance <= args.hard_stop_distance
                    )
                    distance_stop_hit = (front_distance <= stop_distance_effective) or hard_distance_stop_hit
                    center_ok = abs(error_x) <= args.stop_center_tolerance
                    # 红色目标采用更激进停车策略：面积满足即可停车，不强依赖居中。
                    if target_is_red:
                        center_ok = True
                    area_stop_hit = (
                        (area_ratio >= args.stop_area_ratio or area >= float(args.stop_min_area))
                        and center_ok
                    )
                    if area_stop_hit and math.isinf(front_distance) and not args.allow_area_stop_without_lidar:
                        area_stop_hit = False
                    if (
                        area_stop_hit
                        and args.stop_area_max_distance > 0.0
                        and not math.isinf(front_distance)
                        and front_distance > area_stop_max_distance_effective
                    ):
                        # 雷达显示还不够近时，即使图像面积满足，也继续靠近。
                        area_stop_hit = False

                    reached_candidate = distance_stop_hit or area_stop_hit
                    if force_no_spin:
                        # 强制不转圈模式下，优先使用视觉到达快速判定，避免因雷达/居中约束导致循环不退出。
                        visual_reached_fast = (
                            area >= float(args.stop_min_area) * 0.8
                            or area_ratio >= args.stop_area_ratio * 0.8
                        )
                        reached_candidate = reached_candidate or visual_reached_fast
                    if reached_candidate:
                        consecutive_reach_hits += 1
                    else:
                        consecutive_reach_hits = 0

                    required_confirm_frames = max(1, args.stop_confirm_frames)
                    if target_is_red:
                        required_confirm_frames = 1
                    if force_no_spin:
                        required_confirm_frames = 1
                    if reached_candidate and consecutive_reach_hits >= required_confirm_frames:
                        if start_pose is None:
                            first_pose = _extract_odom_pose(first_odom)
                            if first_pose is not None:
                                start_pose = {"x": first_pose[0], "y": first_pose[1], "yaw": first_pose[2], "frame": "odom"}

                        spin_duration = 0.0
                        if spin_after_reach:
                            spin_duration = await _spin_for_turns(
                                ws,
                                angular_z=args.reach_spin_angular_z,
                                turns=args.reach_spin_turns,
                                interval=args.reach_spin_interval,
                            )
                        await _send_cmd_vel(ws, 0.0, 0.0, 0.0)

                        return_result = None
                        if return_to_start:
                            if start_pose is None:
                                _out(
                                    {
                                        "success": False,
                                        "error": "已到达目标，但未找到可用起点坐标，无法自动返程",
                                        "reached": True,
                                        "spin_after_reach": spin_after_reach,
                                        "spin_turns": args.reach_spin_turns if spin_after_reach else 0.0,
                                        "return_to_start": return_to_start,
                                        "red_hold_position_mode": target_is_red,
                                        "force_no_spin": force_no_spin,
                                        "iterations": iterations,
                                        "color": args.color,
                                    }
                                )
                                return
                            return_result = await _return_to_pose(
                                args,
                                x=start_pose["x"],
                                y=start_pose["y"],
                                yaw=start_pose["yaw"],
                                frame=start_pose.get("frame"),
                            )

                        overall_success = (return_result is None) or bool(return_result.get("success"))
                        stop_reason = "target_reached_spin_done_returned" if overall_success and return_to_start else "target_reached_spin_done" if spin_after_reach else "target_reached"
                        if return_result is not None and (not return_result.get("success")):
                            stop_reason = "target_reached_but_return_failed"

                        _out(
                            {
                                "success": overall_success,
                                "reached": True,
                                "stop_reason": stop_reason,
                                "spin_after_reach": spin_after_reach,
                                "spin_angular_z": args.reach_spin_angular_z if spin_after_reach else 0.0,
                                "spin_turns": args.reach_spin_turns if spin_after_reach else 0.0,
                                "spin_duration": spin_duration,
                                "return_to_start": return_to_start,
                                "red_hold_position_mode": target_is_red,
                                "force_no_spin": force_no_spin,
                                "return_result": return_result,
                                "start_pose": start_pose,
                                "stop_trigger": "distance" if distance_stop_hit else "area",
                                "hard_distance_stop_hit": hard_distance_stop_hit,
                                "distance_stop_hit": distance_stop_hit,
                                "area_stop_hit": area_stop_hit,
                                "consecutive_reach_hits": consecutive_reach_hits,
                                "iterations": iterations,
                                "scan": last_scan,
                                "selected_front_distance": None if math.isinf(front_distance) else front_distance,
                                "front_basis_deg": args.front_basis_deg,
                                "last_detection": detection,
                                "last_motion": {"linear_x": 0.0, "angular_z": 0.0, "linear_y": 0.0},
                                "odom_delta": _calc_odom_delta(first_odom, last_odom),
                                "detected_frames": detected_frames,
                                "weak_detected_frames": weak_detected_frames,
                                "color": args.color,
                            }
                        )
                        return

                    if force_no_spin:
                        angular_z = 0.0
                    else:
                        angular_z = max(
                            -args.max_angular_z,
                            min(args.max_angular_z, -args.angular_gain * error_x),
                        )
                    if detection.get("meets_min_area", True):
                        linear_x = args.linear_x if abs(error_x) <= args.center_tolerance else args.slow_linear_x
                    else:
                        # 看到了颜色但面积偏小时，慢速靠近并收紧中心约束，减少误检冲撞。
                        linear_x = args.weak_linear_x if abs(error_x) <= args.weak_center_tolerance else 0.0
                else:
                    consecutive_reach_hits = 0
                    linear_x = 0.0
                    angular_z = 0.0 if force_no_spin else args.search_angular_z

                if front_distance <= args.slow_stop_distance:
                    linear_x = min(linear_x, args.slow_linear_x)

                last_motion = {"linear_x": linear_x, "angular_z": angular_z, "linear_y": 0.0}
                if abs(linear_x) > 1e-6:
                    linear_cmd_steps += 1
                if abs(angular_z) > 1e-6:
                    angular_cmd_steps += 1
                await _drive_for(
                    ws,
                    linear_x=linear_x,
                    angular_z=angular_z,
                    linear_y=0.0,
                    duration=args.step_duration,
                )

            odom_delta = _calc_odom_delta(first_odom, last_odom)
            diagnosis = []
            if detected_frames == 0:
                diagnosis.append("target_not_detected")
            if detected_frames > 0 and max_seen_area < float(args.min_area):
                diagnosis.append("target_detected_but_too_small")
            if linear_cmd_steps > 0 and odom_delta and odom_delta.get("distance", 0.0) < args.min_move_distance:
                diagnosis.append("cmd_vel_sent_but_odom_almost_unchanged")
            if not diagnosis:
                diagnosis.append("max_steps_exceeded")

            suggested_params = {}
            if detected_frames > 0 and max_seen_area > 0.0 and max_seen_area < float(args.min_area):
                suggested_params["min_area"] = max(args.min_visible_area, int(max_seen_area * 0.8))
                suggested_params["stop_area_ratio"] = max(0.004, min(0.10, max_seen_area_ratio * 2.5))
            if odom_delta and linear_cmd_steps > 0 and odom_delta.get("distance", 0.0) < args.min_move_distance:
                suggested_params["check_motion_mode"] = True
                suggested_params["run_move_self_test"] = True

            await _send_cmd_vel(ws, 0.0, 0.0, 0.0)
            _out(
                {
                    "success": False,
                    "error": "在最大迭代次数内未靠近目标",
                    "diagnosis": diagnosis,
                    "iterations": iterations,
                    "scan": last_scan,
                    "selected_front_distance": None if math.isinf(front_distance) else front_distance,
                    "front_basis_deg": args.front_basis_deg,
                    "last_detection": last_detection,
                    "last_motion": last_motion,
                    "detected_frames": detected_frames,
                    "weak_detected_frames": weak_detected_frames,
                    "max_seen_area": max_seen_area,
                    "max_seen_area_ratio": max_seen_area_ratio,
                    "consecutive_reach_hits": consecutive_reach_hits,
                    "linear_cmd_steps": linear_cmd_steps,
                    "angular_cmd_steps": angular_cmd_steps,
                    "odom_delta": odom_delta,
                    "suggested_params": suggested_params,
                    "color": args.color,
                }
            )
    except TimeoutError as e:
        _out({"success": False, "error": str(e), "iterations": iterations, "last_detection": last_detection})
    except (ConnectionRefusedError, OSError) as e:
        _out({"success": False, "error": f"WebSocket 连接失败: {e}", "iterations": iterations})
    except Exception as e:
        _out({"success": False, "error": str(e), "iterations": iterations, "last_detection": last_detection})


async def cmd_navigate(args):
    """通过 WebSocket 请求 move_base 导航（单点/多点）。"""
    try:
        if args.waypoints:
            goals = _parse_waypoints(args.waypoints)
            nav_req = {
                "type": "navigate",
                "frame": args.frame,
                "timeout": args.timeout,
                "waypoints": [
                    {"x": x, "y": y, "yaw": yaw}
                    for x, y, yaw in goals
                ],
            }
        else:
            if args.x is None or args.y is None:
                raise ValueError("请提供 --x --y，或使用 --waypoints")
            goals = [(args.x, args.y, args.yaw)]
            nav_req = {
                "type": "navigate",
                "frame": args.frame,
                "timeout": args.timeout,
                "x": args.x,
                "y": args.y,
                "yaw": args.yaw,
            }

        wait_timeout = max(10.0, args.timeout * max(1, len(goals)) + 5.0)

        ws = await _connect(args.host, args.port)
        async with ws:
            await ws.send(json.dumps(nav_req))
            nav_result = await _recv_nav_result_or_error(ws, timeout=wait_timeout)

        if nav_result.get("success"):
            _out(
                {
                    "success": True,
                    "message": nav_result.get("message", "导航完成"),
                    "frame": nav_result.get("frame", args.frame),
                    "reached": nav_result.get("reached"),
                    "total": nav_result.get("total"),
                }
            )
        else:
            _out(
                {
                    "success": False,
                    "error": nav_result.get("error", "导航失败"),
                    "reached": nav_result.get("reached"),
                    "total": nav_result.get("total"),
                    "failed_index": nav_result.get("failed_index"),
                    "status": nav_result.get("status"),
                }
            )
    except TimeoutError as e:
        _out({"success": False, "error": str(e)})
    except (ConnectionRefusedError, OSError) as e:
        _out({"success": False, "error": f"WebSocket 连接失败: {e}"})
    except Exception as e:
        _out({"success": False, "error": str(e)})


async def cmd_spin_in_place(args):
    """原地转圈指定圈数。"""
    try:
        ws = await _connect(args.host, args.port)
        async with ws:
            spin_duration = await _spin_for_turns(
                ws,
                angular_z=args.angular_z,
                turns=args.turns,
                interval=args.interval,
            )
            await _send_cmd_vel(ws, 0.0, 0.0, 0.0) # Ensure stop

        _out(
            {
                "success": True,
                "message": "原地转圈完成",
                "angular_z": args.angular_z,
                "turns": args.turns,
                "duration": spin_duration,
            }
        )
    except TimeoutError as e:
        _out({"success": False, "error": str(e)})
    except (ConnectionRefusedError, OSError) as e:
        _out({"success": False, "error": f"WebSocket 连接失败: {e}"})
    except Exception as e:
        _out({"success": False, "error": str(e)})


async def cmd_return_to_start_pose(args):
    """返回到指定的起点坐标。"""
    target_x, target_y, target_yaw = None, None, None
    target_frame = args.frame

    if args.x is not None and args.y is not None:
        target_x = args.x
        target_y = args.y
        target_yaw = args.yaw
    elif args.start_pose_file:
        try:
            with open(args.start_pose_file, "r", encoding="utf-8") as f:
                pose_data = json.load(f)
                target_x = pose_data.get("x")
                target_y = pose_data.get("y")
                target_yaw = pose_data.get("yaw", 0.0)
                target_frame = pose_data.get("frame", args.frame) # Use frame from file if available
        except FileNotFoundError:
            _out({"success": False, "error": f"起点坐标文件未找到: {args.start_pose_file}"})
            return
        except json.JSONDecodeError:
            _out({"success": False, "error": f"起点坐标文件格式错误: {args.start_pose_file}"})
            return
        if target_x is None or target_y is None:
            _out({"success": False, "error": f"起点坐标文件缺少 x 或 y: {args.start_pose_file}"})
            return
    else:
        _out({"success": False, "error": "请提供 --x --y 或 --start-pose-file"})
        return

    if target_x is None or target_y is None or target_yaw is None:
        _out({"success": False, "error": "无法确定目标坐标"})
        return

    # Create a temporary args object for _return_to_pose to carry refine parameters
    # This is a bit hacky but avoids refactoring _return_to_pose signature
    return_args = argparse.Namespace(**vars(args))
    return_args.return_timeout = args.timeout # Use general timeout for return
    return_args.return_final_yaw_offset = args.final_yaw_offset

    result = await _return_to_pose(
        return_args,
        x=target_x,
        y=target_y,
        yaw=target_yaw,
        frame=target_frame,
    )
    if result.get("success"):
        _out({"success": True, "message": "已返回起点", "result": result})
    else:
        _out({"success": False, "error": result.get("error", "返回起点失败"), "result": result})


# Renamed cmd_navigate to _cmd_navigate_internal to avoid direct call from main
# The public navigate command will be cmd_navigate_public
async def cmd_navigate_public(args):
    await _cmd_navigate_internal(args)


async def _return_to_pose(args, x: float, y: float, yaw: float, frame: Optional[str] = None) -> dict:
    """导航回指定坐标，并可选执行末端精修。"""
    target_frame = frame or args.return_frame
    try:
        target_yaw = _normalize_angle(yaw + args.return_final_yaw_offset)

        nav_req = {
            "type": "navigate",
            "frame": target_frame,
            "timeout": args.return_timeout,
            "x": x,
            "y": y,
            "yaw": target_yaw,
        }

        ws = await _connect(args.host, args.port)
        async with ws:
            await ws.send(json.dumps(nav_req))
            nav_result = await _recv_nav_result_or_error(ws, timeout=max(10.0, args.return_timeout + 5.0))

        refine_result = None
        if nav_result.get("success") and args.refine_after_nav:
            refine_result = await _refine_to_pose(args, x=x, y=y, yaw=target_yaw)

        if nav_result.get("success") and (not args.refine_after_nav or (refine_result and refine_result.get("success"))):
            return {
                "success": True,
                "message": nav_result.get("message", "已返回起点"),
                "target": {"x":]
                dy = y - pose[1 x, "y": y, "yaw": nav_req["yaw"]},
                "return_final_yaw_offset": args.return_final_yaw_offset,
                "refine": refine_result,
                "frame": nav_result.get("frame", target_frame),
            }
        if nav_result.get("success"):
            return {
                "success": False,
                "error": "返回起点粗导航完成，但精修未达到阈值",
                "target": {"x": x, "y": y, "yaw": nav_req["yaw"]},
                "return_final_yaw_offset": args.return_final_yaw_offset,
                "refine": refine_result,
                "frame": nav_result.get("frame", target_frame),
            }]
                dy = y - pose[1
        nav_error_result = {
            "success": False,
            "error": nav_result.get("error", "返回起点失败"),
            "target": {"x": x, "y": y, "yaw": nav_req["yaw"]},
            "return_final_yaw_offset": args.return_final_yaw_offset,
            "refine": refine_result,
            "frame": nav_result.get("frame", target_frame),
            "status": nav_result.get("status"),
        }
        if args.refine_after_nav:
            # 导航失败时回退到纯里程计精修，避免 move_base 异常时完全无法返程。
            fallback_refine = await _refine_to_pose(args, x=x, y=y, yaw=target_yaw)
            if fallback_refine.]
                dy = y - pose[1get("success"):
                return {
                    "success": True,
                    "message": "导航返程失败，已通过里程计精修回到起点附近",
                    "target": {"x": x, "y": y, "yaw": nav_req["yaw"]},
                    "return_final_yaw_offset": args.return_final_yaw_offset,
                    "refine": fallback_refine,
                    "frame": target_frame,
                    "fallback_mode": "odom_refine_only",
                    "nav_error": nav_error_result,
                }
            nav_error_result["fallback_refine"] = fallback_refine
        return nav_error_result
    except TimeoutError as e:]
                dy = y - pose[1
        return {"success": False, "error": str(e)}
    except (ConnectionRefusedError, OSError) as e:
        return {"success": False, "error": f"WebSocket 连接失败: {e}"}
    except Exception as e:
        return {"success": False, "error": str(e)}


async def _refine_to_pose(args, x: float, y: float, yaw: float) -> dict:
    last_pose = None
    final_dist = None
    final_yaw_err = None
    steps = 0
    near_target_radius = max(ar]
                dy = y - pose[1gs.refine_pos_tol * 3.0, 0.12)
    try: # NOSONAR
        ws = await _connect(args.host, args.port)
        async with ws:
            for steps in range(1, max(1, args.refine_max_steps) + 1):
                state = await _recv_state(ws, timeout=3.0)
                odom = state.get("odom", {}) if isinstance(state, dict) else {}
                pose = _extract_odom_pose(odom)
                if pose is None:
                    await _drive_for(ws, linear_x=0.0, angular_z=0.0, linear_y=0.0, duration=args.refine_step_duration)
                    continue

                last_pose = {"x": pose[0], "y": pose[1], "yaw": pose[2]}
                dx = x - pose[0]
                dy = y - pose[1]
                dist = math.hypot(dx, dy)
                yaw_err = _normalize_angle(yaw - pose[2])
                final_dist = dist
                final_yaw_err = yaw_err

                if dist <= args.refine_pos_tol and abs(yaw_err) <= args.refine_yaw_tol:
                    await _send_cmd_vel(ws, 0.0, 0.0, 0.0)
                    return {
                        "success": True,
                        "steps": steps,
                        "distance_error": dist,
                        "yaw_error": yaw_err,
                        "last_pose": last_pose,
                    }

                if dist > args.refine_pos_tol:
                    heading = math.atan2(dy, dx)
                    heading_err = _normalize_angle(heading - pose[2])
                    angular_z = _clamp(
                        args.refine_heading_kp * heading_err,
                        -args.refine_max_angular_z,
                        args.refine_max_angular_z,
                    )
                    heading_tolerance = args.refine_heading_tolerance
                    if dist <= near_target_radius:
                        # 近目标时收紧朝向要求，避免边偏航边前冲导致过头。
                        heading_tolerance = min(heading_tolerance, 0.25)
                    if abs(heading_err) <= heading_tolerance:
                        raw_linear = args.refine_linear_kp * dist
                        if dist <= near_target_radius:
                            # 近目标时允许更小速度并限制最大线速度，减少惯性越位。
                            near_max_linear = min(args.refine_max_linear_x, max(args.refine_min_linear_x, 0.12))
                            linear_x = _clamp(raw_linear, 0.0, near_max_linear)
                        else:
                            linear_x = _clamp(
                                raw_linear,
                                args.refine_min_linear_x,
                                args.refine_max_linear_x,
                            )
                    else:
                        linear_x = 0.0
                else:
                    linear_x = 0.0
                    angular_z = _clamp(
                        args.refine_yaw_kp * yaw_err,
                        -args.refine_max_angular_z,
                        args.refine_max_angular_z,
                    )

                drive_duration = args.refine_step_duration
                if dist <= near_target_radius:
                    # 近目标时缩短每次驱动时间，进一步抑制冲过终点。
                    drive_duration = min(args.refine_step_duration, 0.10)
                await _drive_for(
                    ws,
                    linear_x=linear_x,
                    angular_z=angular_z,
                    linear_y=0.0,
                    duration=drive_duration,
                )

            await _send_cmd_vel(ws, 0.0, 0.0, 0.0)
            return {
                "success": False,
                "steps": steps,
                "distance_error": final_dist,
                "yaw_error": final_yaw_err,
                "last_pose": last_pose,
            }
    except Exception as e:
        return {
            "success": False,
            "steps": steps,
            "distance_error": final_dist,
            "yaw_error": final_yaw_err,
            "last_pose": last_pose,
            "error": str(e),
        }


def cmd_take_photo(args):
    """SSH 触发拍照，然后 scp 图片到本地。"""
    ssh_target = f"{args.ssh_user}@{args.ssh_host}"
    scp_src = f"{ssh_target}:{REMOTE_PHOTO_PATH}"
    local_out = args.output

    try:
        result = subprocess.run(
            [
                "sshpass",
                "-p",
                args.ssh_pass,
                "ssh",
                "-o",
                "StrictHostKeyChecking=no",
                ssh_target,
                REMOTE_PHOTO_CMD,
            ],
            capture_output=True,
            text=True,
            timeout=20,
        )
        if result.returncode != 0:
            _out({"success": False, "error": f"拍照命令失败: {result.stderr.strip()}"})
            return

        result = subprocess.run(
            [
                "sshpass",
                "-p",
                args.ssh_pass,
                "scp",
                "-o",
                "StrictHostKeyChecking=no",
                scp_src,
                local_out,
            ],
            capture_output=True,
            text=True,
            timeout=20,
        )
        if result.returncode != 0:
            _out({"success": False, "error": f"图片传输失败: {result.stderr.strip()}"})
            return

        _out(
            {
                "success": True,
                "local_path": local_out,
                "remote_path": REMOTE_PHOTO_PATH,
            }
        )
    except FileNotFoundError:
        _out(
            {
                "success": False,
                "error": "未找到 sshpass，请先安装: brew install hudochenkov/sshpass/sshpass",
            }
        )
    except subprocess.TimeoutExpired:
        _out({"success": False, "error": "SSH/SCP 操作超时"})
    except Exception as e:
        _out({"success": False, "error": str(e)})


